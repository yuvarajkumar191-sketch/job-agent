# ============================================
# JOB AGENT - Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub
# ============================================

# --- SUPABASE (free at supabase.com) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- OPENROUTER AI (free tier at openrouter.ai) ---
# Used for job scoring, CV tailoring, cover letter generation
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
# Other free options: google/gemma-3-27b-it:free, meta-llama/llama-3.1-8b-instruct:free

# --- APIFY (job scraping - free $5 credit at apify.com) ---
APIFY_API_TOKEN=your-apify-api-token
APIFY_ACTOR_ID=fetchclub~linkedin-jobs-scraper

# --- N8N (self-hosted on Railway - free) ---
# Your n8n instance URL after deploying to Railway
N8N_BASE_URL=https://your-n8n.up.railway.app
N8N_WEBHOOK_SECRET=your-random-secret-string-min-32-chars

# --- INTERNAL API SECURITY ---
# A random string n8n uses to authenticate with your backend
INTERNAL_API_KEY=your-random-internal-api-key-min-32-chars

# --- NEXT AUTH (login to your dashboard) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# --- YOUR PROFILE (used by AI prompts) ---
USER_EMAIL=your-email@example.com
USER_NAME=Yuvaraj Kumar
USER_LINKEDIN=https://www.linkedin.com/in/your-profile

# --- VERCEL (auto-set when deployed, leave blank locally) ---
VERCEL_URL=
